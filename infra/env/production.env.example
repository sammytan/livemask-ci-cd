# LiveMask production runtime.
# Copy to production.env on the server and fill real values there.
# Do not commit production.env.

LIVEMASK_STACK_NAME=livemask-production

# Production images are immutable release tags.
BACKEND_IMAGE=ghcr.io/myaidevs/livemask-backend:v0.1.0
ADMIN_IMAGE=ghcr.io/myaidevs/livemask-admin:v0.1.0
NODEAGENT_IMAGE=ghcr.io/myaidevs/livemask-nodeagent:v0.1.0

# Prefer cloud PostgreSQL/Redis in production.
DB_DSN=postgres://user:password@postgres.example.com:5432/livemask?sslmode=require
REDIS_ADDR=redis.example.com:6379

# Use internal deps only for small private deployments:
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
POSTGRES_USER=livemask
POSTGRES_PASSWORD=change-me
POSTGRES_DB=livemask
POSTGRES_PORT=15432
REDIS_PORT=16379

LIVEMASK_BACKEND_HTTP_PORT=18080
LIVEMASK_ADMIN_PORT=3001
LIVEMASK_NODEAGENT_PORT=19090

BACKEND_VERSION=v0.1.0
NODE_ID=prod-node-001
AGENT_VERSION=v0.1.0
POLL_INTERVAL_SEC=60
