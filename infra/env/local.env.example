# LiveMask local Docker runtime.
# Copy to local.env and adjust only when ports or mirrors conflict.

LIVEMASK_STACK_NAME=livemask-local

POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
BACKEND_GO_IMAGE=golang:1.25-alpine
ADMIN_NODE_IMAGE=node:22-alpine
WEBSITE_NODE_IMAGE=node:22-alpine
APP_FLUTTER_IMAGE=ghcr.io/cirruslabs/flutter:stable
NODEAGENT_GO_IMAGE=golang:1.26-alpine

POSTGRES_USER=livemask
POSTGRES_PASSWORD=livemask
POSTGRES_DB=livemask
POSTGRES_PORT=15432
REDIS_PORT=16379

LIVEMASK_BACKEND_HTTP_PORT=18080
LIVEMASK_ADMIN_PORT=3001
LIVEMASK_WEBSITE_PORT=3002
LIVEMASK_APP_WEB_PORT=3003
LIVEMASK_NODEAGENT_PORT=19090

BACKEND_VERSION=dev-local
GOPROXY=https://goproxy.cn,direct
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://127.0.0.1:3002,http://127.0.0.1:3003,http://localhost:3001,http://localhost:3002,http://localhost:3003

# Keep Admin node detail logs fresh in local dev. NodeAgent writes to Docker
# stdout regardless; this controls upload into Backend observability logs.
LOG_UPLOAD_ENABLED=true

# Dev-only seed users. Never copy these values to production.
DEV_SEED_USERS=true
DEV_DEFAULT_PASSWORD=DevPass123!
DEV_ADMIN_EMAIL=admin@livemask.dev
DEV_ADMIN_PASSWORD=AdminPass123!
DEV_SPONSOR_EMAIL=sponsor@livemask.dev
DEV_SPONSOR_PASSWORD=SponsorPass123!
DEV_AMBASSADOR_EMAIL=ambassador@livemask.dev
DEV_AMBASSADOR_PASSWORD=AmbassadorPass123!
DEV_SUBSCRIBER_EMAIL=subscriber@livemask.dev
DEV_SUBSCRIBER_PASSWORD=SubscriberPass123!
DEV_USER_EMAIL=user@livemask.dev
DEV_USER_PASSWORD=UserPass123!
