# LiveMask staging runtime.
# This can use internal PostgreSQL/Redis containers or external cloud services.

LIVEMASK_STACK_NAME=livemask-staging

POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

POSTGRES_USER=livemask
POSTGRES_PASSWORD=change-me
POSTGRES_DB=livemask
POSTGRES_PORT=15432
REDIS_PORT=16379

# For internal deps:
DB_DSN=postgres://livemask:change-me@postgres:5432/livemask?sslmode=disable
REDIS_ADDR=redis:6379

# For cloud deps, set --no-deps and replace DB_DSN/REDIS_ADDR:
# DB_DSN=postgres://user:password@cloud-postgres.example.com:5432/livemask?sslmode=require
# REDIS_ADDR=cloud-redis.example.com:6379

BACKEND_IMAGE=ghcr.io/myaidevs/livemask-backend:dev
ADMIN_IMAGE=ghcr.io/myaidevs/livemask-admin:dev
WEBSITE_IMAGE=ghcr.io/myaidevs/livemask-website:dev
NODEAGENT_IMAGE=ghcr.io/myaidevs/livemask-nodeagent:dev

LIVEMASK_BACKEND_HTTP_PORT=18080
LIVEMASK_ADMIN_PORT=3001
LIVEMASK_WEBSITE_PORT=3002
LIVEMASK_NODEAGENT_PORT=19090
BACKEND_VERSION=staging

# Optional dev/staging seed users. Keep disabled unless this staging stack is
# private and used for QA only. Never enable in production.
DEV_SEED_USERS=false
DEV_DEFAULT_PASSWORD=
DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=
DEV_SPONSOR_EMAIL=
DEV_SPONSOR_PASSWORD=
DEV_AMBASSADOR_EMAIL=
DEV_AMBASSADOR_PASSWORD=
DEV_SUBSCRIBER_EMAIL=
DEV_SUBSCRIBER_PASSWORD=
DEV_USER_EMAIL=
DEV_USER_PASSWORD=
