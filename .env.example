# Backend HTTP port exposed on host (default 18080)
LIVEMASK_BACKEND_HTTP_PORT=18080

# PostgreSQL
POSTGRES_USER=livemask
POSTGRES_PASSWORD=livemask
POSTGRES_DB=livemask

# PostgreSQL host port (avoid conflict with server's native PG, default 15432)
POSTGRES_PORT=15432

# Redis host port (avoid conflict with server's native Redis, default 16379)
REDIS_PORT=16379

# Backend version injected into /api/v1/health response (default 0.0.0)
BACKEND_VERSION=0.0.0

# Backend repository URL and ref for Docker build (default dev branch)
BACKEND_REPO_URL=https://github.com/MyAiDevs/livemask-backend.git
BACKEND_REF=dev

# Dev-only seed admin credentials
# Used by scripts/api-smoke.sh for auth smoke testing.
# Backend seeds these accounts only when DEV_ADMIN_EMAIL is set (dev/staging only).
# DO NOT set in production — production must use real user registration.
DEV_ADMIN_EMAIL=admin@livemask.dev
DEV_ADMIN_PASSWORD=AdminPass123!
DEV_USER_EMAIL=user@livemask.dev
DEV_USER_PASSWORD=UserPass123!

# Local Docker runtime image overrides.
# Keep defaults for normal use. If Docker Hub is slow, point these variables at
# an available registry mirror while preserving the same image/tag.
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
BACKEND_GO_IMAGE=golang:1.22-alpine
ADMIN_NODE_IMAGE=node:22-alpine
NODEAGENT_GO_IMAGE=golang:1.26-alpine

# Runtime deployment images. Production should use immutable release tags.
BACKEND_IMAGE=ghcr.io/myaidevs/livemask-backend:dev
ADMIN_IMAGE=ghcr.io/myaidevs/livemask-admin:dev
NODEAGENT_IMAGE=ghcr.io/myaidevs/livemask-nodeagent:dev
